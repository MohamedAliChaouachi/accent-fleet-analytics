# Copy this file to .env and fill in real values.
# The pipeline reads from this via pydantic-settings.

# --- PostgreSQL connection ---
# We run inside an Azure VM and the database is also hosted on Azure.
# For Azure Database for PostgreSQL (Flexible Server) the host looks like:
#   <server-name>.postgres.database.azure.com
# and PG_SSLMODE MUST be "require" (or stricter).
# For a local docker postgres started via `make up-localdb` use PG_HOST=postgres
# (inside the compose network) or PG_HOST=localhost from the host machine, with PG_SSLMODE=prefer.
PG_HOST=your-server.postgres.database.azure.com
PG_PORT=5432
PG_DATABASE=accent_fleet
PG_USER=accent_admin
PG_PASSWORD=change_me
PG_SSLMODE=require
PG_SCHEMA_STAGING=staging
PG_SCHEMA_WAREHOUSE=warehouse
PG_SCHEMA_MARTS=marts

# --- Pipeline behaviour ---
# dev | staging | prod
PIPELINE_ENV=dev
PIPELINE_LOG_LEVEL=INFO
PIPELINE_BATCH_SIZE=50000
# window overlap to catch late data
PIPELINE_OVERLAP_MINUTES=10
# how often the batch scheduler runs
PIPELINE_INCREMENTAL_LOOKBACK_MINUTES=5

# --- MLflow ---
# When running fully containerized, this resolves inside the compose network.
# From the host machine use http://localhost:5000.
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=device-behavior-clustering
MLFLOW_MODEL_NAME=device-clustering
MLFLOW_MODEL_STAGE=Production

# --- API service ---
API_HOST=0.0.0.0
API_PORT=8000
# URL the dashboard (and tests) use to reach the API.
# Inside the compose network: http://api:8000
# From the host: http://localhost:8000
API_BASE_URL=http://api:8000

# Shared secret for admin endpoints (POST /admin/reload-model and any future
# privileged routes). Caller must send `X-API-Key: <value>`. Leave EMPTY in
# dev to disable admin endpoints entirely (they will 401 fail-closed). Use a
# long random string in any non-laptop environment — e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_ADMIN_KEY=

# --- Dashboard ---
DASHBOARD_PORT=8501
DASHBOARD_BASE_URL=http://localhost:8501

# --- Streaming (future) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PATH=fleet.path.v1
KAFKA_TOPIC_STOP=fleet.stop.v1
KAFKA_TOPIC_OVERSPEED=fleet.overspeed.v1
KAFKA_CONSUMER_GROUP=accent-fleet-phase3
